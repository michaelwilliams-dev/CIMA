function directorAppointmentsMarkdownTable(headers = [], rows = []) {
  const safe = (value) => {
    if (value === true) return "Yes";
    if (value === false) return "No";
    if (value === 0) return "0";
    return String(value ?? "Not returned").replace(/\|/g, "/").trim() || "Not returned";
  };

  const cleanHeaders = headers.map(safe);
  const cleanRows = rows.map((row) => row.map(safe));

  return [
    `| ${cleanHeaders.join(" | ")} |`,
    `| ${cleanHeaders.map(() => "---").join(" | ")} |`,
    ...cleanRows.map((row) => `| ${row.join(" | ")} |`)
  ].join("\n");
}

function buildDirectorAppointmentsReportText({
  companyNumber,
  companyName,
  bundle
}) {
  const checkedAt = new Date().toISOString();
  const profile = bundle.profile || {};
  const officers = bundle.officers || {};
  const officerAppointments = Array.isArray(bundle.officer_appointments)
    ? bundle.officer_appointments
    : [];

  const subjectCompanyNumber = normaliseCompanyNumber(
    profile.company_number ||
    bundle.company_number ||
    companyNumber
  );

  const officerItems = Array.isArray(officers.items) ? officers.items : [];

  const makeOfficerKey = (name = "") =>
    String(name || "")
      .toUpperCase()
      .replace(/[^A-Z0-9\s]/g, " ")
      .replace(/\s+/g, " ")
      .trim();

  const activeSubjectDirectors = officerItems
    .filter((officer) => !officer.resigned_on)
    .filter((officer) =>
      String(officer.officer_role || "")
        .toLowerCase()
        .includes("director")
    )
    .filter((officer) => officer.name)
    .map((officer) => ({
      name: officer.name || "Unknown director",
      key: makeOfficerKey(officer.name || ""),
      officer_role: officer.officer_role || "director",
      appointed_on: officer.appointed_on || "Not returned",
      date_of_birth: officer.date_of_birth || null,
      nationality: officer.nationality || "Not returned",
      country_of_residence: officer.country_of_residence || "Not returned"
    }));

  const activeSubjectDirectorKeys = new Set(
    activeSubjectDirectors.map((director) => director.key)
  );

  const activeOfficerRows = officerItems
    .filter((officer) => !officer.resigned_on)
    .map((officer) => [
      officer.name || "Not returned",
      officer.officer_role || "Not returned",
      officer.appointed_on || "Not returned",
      officer.resigned_on || "",
      officer.date_of_birth
        ? `${officer.date_of_birth.month || ""}/${officer.date_of_birth.year || ""}`
        : "Not returned",
      officer.nationality || "Not returned",
      officer.country_of_residence || "Not returned"
    ]);

  const activeDirectorRows = activeSubjectDirectors.map((director) => [
    director.name,
    director.officer_role,
    director.appointed_on,
    director.date_of_birth
      ? `${director.date_of_birth.month || ""}/${director.date_of_birth.year || ""}`
      : "Not returned",
    director.nationality,
    director.country_of_residence
  ]);

  const activeDirectorAppointmentsOnly = officerAppointments.filter((officer) => {
    const officerNameKey = makeOfficerKey(officer.officer_name || "");
    const role = String(officer.company_role || "").toLowerCase();

    return (
      activeSubjectDirectorKeys.has(officerNameKey) &&
      role.includes("director")
    );
  });

  const excludedOfficerAppointments = officerAppointments.filter((officer) => {
    const officerNameKey = makeOfficerKey(officer.officer_name || "");
    return !activeSubjectDirectorKeys.has(officerNameKey);
  });

  const sourceStatus = bundle.source_status || {};
  const officerNetworkTrace = bundle.officer_network_trace || {};

  const groupedOfficerSections = [];

  activeDirectorAppointmentsOnly.forEach((officer, index) => {
    const officerName = officer.officer_name || "Unknown director";

    const allAppointments = Array.isArray(officer.all_appointments)
      ? officer.all_appointments
      : [];

    const activeAppointmentsAcrossCompanies = allAppointments.filter(
      (appointment) => !appointment.resigned_on
    );

    const resignedAppointmentsAcrossCompanies = allAppointments.filter(
      (appointment) => appointment.resigned_on
    );

    const appointmentRows = allAppointments.map((appointment) => {
      const appointmentCompanyNumber = normaliseCompanyNumber(
        appointment.company_number || ""
      );

      const isSubjectCompany = appointmentCompanyNumber === subjectCompanyNumber;
      const isResigned = Boolean(appointment.resigned_on);

      let statusText = "ACTIVE";
      if (isResigned) {
        statusText = `Resigned ${appointment.resigned_on}`;
      }

      const relationshipText = isSubjectCompany
        ? "Subject company"
        : "Other appointment company";

      return [
        appointment.company_name || "Not returned",
        appointment.company_number || "Not returned",
        appointment.role || "Not returned",
        appointment.appointed_on || "Not returned",
        `${statusText} - ${relationshipText}`
      ];
    });

    groupedOfficerSections.push(
      `## 5.${index + 1}. Active director: ${officerName}`,
      "",
      directorAppointmentsMarkdownTable(
        ["Area", "Value"],
        [
          ["Subject company role", officer.company_role || "Not returned"],
          ["Subject company appointed", officer.company_appointed_on || "Not returned"],
          ["Total appointment records returned for this person", officer.total_results ?? allAppointments.length],
          ["Active appointment records across all companies", activeAppointmentsAcrossCompanies.length],
          ["Resigned appointment records across all companies", resignedAppointmentsAcrossCompanies.length],
          ["Companies House appointment source", officer.ok === true ? "OK" : `Not OK: ${officer.error || "Unknown error"}`]
        ]
      ),
      "",
      appointmentRows.length
        ? directorAppointmentsMarkdownTable(
            ["Company", "Company number", "Role", "Appointed", "Status / relationship"],
            appointmentRows
          )
        : "No appointment companies were returned for this active director.",
      ""
    );
  });

  return [
    "# AIVS Company Examiner",
    "# Director Appointments Report",
    "",
    `Generated at: ${checkedAt}`,
    `Backend build: ${BUILD_ISO}`,
    "",
    "## 1. Subject company",
    "",
    directorAppointmentsMarkdownTable(
      ["Area", "Value"],
      [
        ["Company", profile.company_name || companyName || "Not returned"],
        ["Company number", subjectCompanyNumber || companyNumber || "Not returned"],
        ["Companies House status", profile.company_status || "Not returned"],
        ["Company type", profile.type || "Not returned"],
        ["Jurisdiction", profile.jurisdiction || "Not returned"]
      ]
    ),
    "",
    "## 2. Source status",
    "",
    directorAppointmentsMarkdownTable(
      ["Source", "Status", "Error / note"],
      [
        [
          "Company profile",
          sourceStatus.profile?.ok
            ? `${sourceStatus.profile.status || ""} / OK`
            : `${sourceStatus.profile?.status || "Not returned"} / Not OK`,
          sourceStatus.profile?.error || ""
        ],
        [
          "Officers",
          sourceStatus.officers?.ok
            ? `${sourceStatus.officers.status || ""} / OK`
            : `${sourceStatus.officers?.status || "Not returned"} / Not OK`,
          sourceStatus.officers?.error || ""
        ],
        [
          "Officer appointments",
          sourceStatus.officer_appointments?.ok
            ? `${sourceStatus.officer_appointments.status || ""} / OK`
            : `${sourceStatus.officer_appointments?.status || "Not returned"} / Not OK`,
          sourceStatus.officer_appointments?.error || ""
        ]
      ]
    ),
    "",
    "## 3. Active officers returned for subject company",
    "",
    activeOfficerRows.length
      ? directorAppointmentsMarkdownTable(
          ["Officer", "Role", "Appointed", "Resigned", "DOB month/year", "Nationality", "Residence"],
          activeOfficerRows
        )
      : "No active officer rows were returned by the Companies House officer endpoint.",
    "",
    "## 4. Active directors checked in this report",
    "",
    activeDirectorRows.length
      ? directorAppointmentsMarkdownTable(
          ["Director", "Role", "Appointed", "DOB month/year", "Nationality", "Residence"],
          activeDirectorRows
        )
      : "No active director rows were returned by the Companies House officer endpoint.",
    "",
    "## 5. Appointment records grouped by active director",
    "",
    activeDirectorAppointmentsOnly.length
      ? "Only active directors of the subject company are expanded below. Secretaries and resigned/historic directors are excluded from this grouped section."
      : "No active director appointment expansion was returned.",
    "",
    ...groupedOfficerSections,
    `## ${6 + activeDirectorAppointmentsOnly.length}. Exclusions applied`,
    "",
    directorAppointmentsMarkdownTable(
      ["Area", "Value"],
      [
        ["Active officers returned for subject company", activeOfficerRows.length],
        ["Active directors expanded in grouped section", activeDirectorAppointmentsOnly.length],
        ["Officer appointment records excluded from grouped section", excludedOfficerAppointments.length],
        ["Reason for exclusion", "Not an active director of the subject company, or role was secretary/resigned/historic."]
      ]
    ),
    "",
    `## ${7 + activeDirectorAppointmentsOnly.length}. Review notes`,
    "",
    "- This report uses Companies House officer appointment links returned for the subject company.",
    "- The grouped appointment section is limited to active directors of the subject company only.",
    "- Secretaries are not shown as directors.",
    "- Resigned or historic subject-company directors are not expanded in the grouped active-director section.",
    "- Active appointment record counts are appointment records for that person across all companies; they are not the number of active directors of the subject company.",
    "- Appointment records are not identity verification.",
    "- This is not a sanctions, criminal-record, credit, insolvency, adverse-media or regulatory enforcement check.",
    "- Human review against Companies House source records is required before reliance.",
    "",
    `## ${8 + activeDirectorAppointmentsOnly.length}. Network trace limit`,
    "",
    directorAppointmentsMarkdownTable(
      ["Area", "Value"],
      [
        ["Trace skipped", officerNetworkTrace.skipped === true ? "Yes" : "No"],
        ["Officer count returned in current bundle", officerNetworkTrace.officer_count ?? "Not returned"],
        ["Trace threshold", officerNetworkTrace.threshold ?? "Not returned"],
        ["Message", officerNetworkTrace.message || "Not applicable"]
      ]
    ),
    "",
    "AIVS Software Limited copyright 2026. All rights reserved."
  ].join("\n");
}


app.post("/send-director-appointments-report-email", async (req, res) => {
  try {
    const companyNumber = normaliseCompanyNumber(req.body.companyNumber || "");
    const companyName = String(req.body.companyName || "").trim();

    const toEmail = String(req.body.toEmail || "").trim();
    const secondEmail = String(req.body.secondEmail || "").trim();

    if (!companyNumber) {
      return res.status(400).json({
        ok: false,
        error: "Company number required.",
        build_iso: BUILD_ISO
      });
    }

    if (!toEmail) {
      return res.status(400).json({
        ok: false,
        error: "Primary email address required.",
        build_iso: BUILD_ISO
      });
    }

    const bundle = await getCompaniesHouseBundle(companyNumber);

    if (!bundle.ok) {
      return res.status(502).json({
        ok: false,
        error: bundle.error || "Companies House bundle failed.",
        build_iso: BUILD_ISO,
        companies_house: bundle
      });
    }

    const safeCompany =
      bundle.profile?.company_name ||
      companyName ||
      companyNumber ||
      "Company";

    const reportText = buildDirectorAppointmentsReportText({
      companyNumber,
      companyName: safeCompany,
      bundle
    });

    const safeFilenameCompany = String(safeCompany)
      .replace(/[^\w.\-]+/g, "_")
      .replace(/^_+|_+$/g, "")
      .slice(0, 80) || "Company";

    const pdfFilename = `AIVS_Director_Appointments_Report_${safeFilenameCompany}.pdf`;
    const docxFilename = `AIVS_Director_Appointments_Report_${safeFilenameCompany}.docx`;

    const pdfBuffer = await buildReportPdfBuffer({
      companyName: safeCompany,
      companyNumber,
      riskFocus: "Director appointments",
      urgencyLevel: "N/A",
      reportText
    });

    const docxBuffer = await buildReportDocxBuffer({
      companyName: safeCompany,
      companyNumber,
      riskFocus: "Director appointments",
      urgencyLevel: "N/A",
      reportText
    });

    const bodyText = [
      "AIVS Company Examiner director appointments report attached.",
      "",
      `Company: ${safeCompany}`,
      `Company number: ${companyNumber}`,
      "",
      "Attached files:",
      `- ${pdfFilename}`,
      `- ${docxFilename}`,
      "",
      "This report uses Companies House officer appointment links and requires human review before reliance.",
      "",
      "AIVS Software Limited copyright 2026. All rights reserved."
    ].join("\n");

    const subject = `AIVS Director Appointments Report - ${safeCompany}`;

    const recipients = [toEmail, secondEmail]
      .map((email) => String(email || "").trim())
      .filter(Boolean);

    const sent = [];

    for (const recipient of recipients) {
      const mailjetResult = await sendResultEmail({
        toEmail: recipient,
        subject,
        bodyText,
        pdfBuffer,
        pdfFilename,
        docxBuffer,
        docxFilename
      });

      sent.push({
        to: recipient,
        status: mailjetResult?.Status || "sent"
      });
    }

    return res.json({
      ok: true,
      build_iso: BUILD_ISO,
      sent_at: new Date().toISOString(),
      sent,
      companyNumber,
      companyName: safeCompany,
      pdfFilename,
      docxFilename,
      attachment_bytes: {
        pdf: pdfBuffer.length,
        docx: docxBuffer.length
      },
      officer_appointments_count: Array.isArray(bundle.officer_appointments)
        ? bundle.officer_appointments.length
        : 0
    });
  } catch (err) {
    console.error("ERROR /send-director-appointments-report-email failed:", err);

    return res.status(500).json({
      ok: false,
      error: "Director appointments report email failed.",
      detail: err.message,
      build_iso: BUILD_ISO
    });
  }
});

