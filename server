async function fetchAccountsPdfForCompanyByIndex(companyNumber, accountsIndex = 0) {
  const number = normaliseCompanyNumber(companyNumber);

  const index = Number.isInteger(Number(accountsIndex))
    ? Math.max(0, Math.min(2, Number(accountsIndex)))
    : 0;

  if (!number) {
    return {
      ok: false,
      error: "Company number required.",
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`
    };
  }

  let filingHistory = await companiesHouseGet(
    `/company/${encodeURIComponent(number)}/filing-history?category=accounts&items_per_page=100`
  );

  let filings = filingHistory.data?.items || [];

  if (!filings.length) {
    filingHistory = await companiesHouseGet(
      `/company/${encodeURIComponent(number)}/filing-history?items_per_page=100`
    );

    filings = filingHistory.data?.items || [];
  }

  const accountFilings = filings
    .filter((filing) => {
      const category = String(filing.category || "").toLowerCase();
      const type = String(filing.type || "").toUpperCase();
      const description = String(filing.description || "").toLowerCase();

      return (
        filing.links?.document_metadata &&
        (
          category === "accounts" ||
          type === "AA" ||
          description.includes("accounts")
        )
      );
    })
    .sort((a, b) => {
      const aDate = String(a.date || a.action_date || "");
      const bDate = String(b.date || b.action_date || "");
      return bDate.localeCompare(aDate);
    });

  if (!accountFilings.length) {
    return {
      ok: false,
      error: "No accounts filings with downloadable document metadata were found.",
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`,
      available_accounts_filings: 0
    };
  }

  const selectedFiling = accountFilings[index];

  if (!selectedFiling) {
    return {
      ok: false,
      error: `Accounts filing for Year ${index + 1} was not found. Only ${accountFilings.length} accounts filing(s) were available.`,
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`,
      available_accounts_filings: accountFilings.length
    };
  }

  const metadataResult = await companiesHouseGetUrl(
    selectedFiling.links.document_metadata
  );

  if (!metadataResult.ok) {
    return {
      ok: false,
      error: `Could not retrieve Companies House document metadata: ${metadataResult.error || metadataResult.status}`,
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`,
      filing: selectedFiling,
      available_accounts_filings: accountFilings.length
    };
  }

  const metadata = metadataResult.data || {};
  const pdfResource = metadata.resources?.["application/pdf"] || null;

  let pdfContentLink =
    pdfResource?.links?.document ||
    pdfResource?.link ||
    metadata.links?.document ||
    "";

  if (!pdfContentLink && metadata.links?.self) {
    pdfContentLink = `${String(metadata.links.self).replace(/\/$/, "")}/content`;
  }

  if (!pdfContentLink) {
    return {
      ok: false,
      error: `No PDF download link was returned by Companies House for Year ${index + 1} accounts.`,
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`,
      filing: selectedFiling,
      available_accounts_filings: accountFilings.length
    };
  }

  const pdfResult = await companiesHouseFetchBinary(
    pdfContentLink,
    "application/pdf"
  );

  if (!pdfResult.ok || !pdfResult.buffer) {
    return {
      ok: false,
      error: `Could not retrieve Companies House accounts PDF: ${pdfResult.error || pdfResult.status}`,
      buffer: null,
      filename: null,
      accounts_index: index,
      accounts_label: `Year ${index + 1}`,
      filing: selectedFiling,
      available_accounts_filings: accountFilings.length
    };
  }

  const filingDate =
    selectedFiling.date ||
    selectedFiling.action_date ||
    "undated";

  const filename = `Companies_House_accounts_year_${index + 1}_${number}_${filingDate}.pdf`
    .replace(/[^\w.\-]+/g, "_");

  return {
    ok: true,
    error: null,
    buffer: pdfResult.buffer,
    filename,
    filing: selectedFiling,
    accounts_index: index,
    accounts_label: `Year ${index + 1}`,
    available_accounts_filings: accountFilings.length
  };
}

