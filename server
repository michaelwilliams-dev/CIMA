async function companiesHouseFetchBinary(urlOrPath, accept = "application/pdf") {
  if (!COMPANIES_HOUSE_API_KEY) {
    return {
      ok: false,
      status: 0,
      error: "COMPANIES_HOUSE_API_KEY not set.",
      buffer: null,
      contentType: null
    };
  }

  const url = absoluteCompaniesHouseUrl(urlOrPath);

  try {
    const res = await fetch(url, {
      method: "GET",
      headers: companiesHouseHeaders(accept)
    });

    const contentType = res.headers.get("content-type") || accept;

    if (!res.ok) {
      const text = await res.text().catch(() => "");
      return {
        ok: false,
        status: res.status,
        error: text || `Companies House binary request failed: ${res.status}`,
        buffer: null,
        contentType
      };
    }

    const arrayBuffer = await res.arrayBuffer();

    return {
      ok: true,
      status: res.status,
      error: null,
      buffer: Buffer.from(arrayBuffer),
      contentType
    };
  } catch (err) {
    return {
      ok: false,
      status: 0,
      error: err.message,
      buffer: null,
      contentType: null
    };
  }
}

