    const companyNumber = normaliseCompanyNumber(req.body.companyNumber || "");
    const companyName = String(req.body.companyName || "").trim();

    const toEmail = String(req.body.toEmail || "").trim();
    const secondEmail = String(req.body.secondEmail || "").trim();

    const activeDirectors = Array.isArray(req.body.activeDirectors)
      ? req.body.activeDirectors
      : Array.isArray(req.body.directors)
        ? req.body.directors
        : null;

    if (!companyNumber) {
      return res.status(400).json({
        ok: false,
        error: "Company number required.",
        build_iso: BUILD_ISO
      });
    }

    if (!toEmail) {
      return res.status(400).json({
        ok: false,
        error: "Primary email address required.",
        build_iso: BUILD_ISO
      });
    }


    const report = await buildDirectorDisqualificationEmailReport({
      companyName,
      companyNumber,
      activeDirectors
    });

    const recipients = [toEmail, secondEmail]
      .map((email) => String(email || "").trim())
      .filter(Boolean);

      const safeCompany =
        report.company_name ||
        companyName ||
        companyNumber ||
        "Company";

    const safeFilenameCompany = String(safeCompany)
      .replace(/[^\w.\-]+/g, "_")
      .replace(/^_+|_+$/g, "")
      .slice(0, 80) || "Company";

    const pdfFilename = `AIVS_Director_Disqualification_Report_${safeFilenameCompany}.pdf`;
    const docxFilename = `AIVS_Director_Disqualification_Report_${safeFilenameCompany}.docx`;

    const pdfBuffer = await buildReportPdfBuffer({
      companyName: safeCompany,
      companyNumber,
      riskFocus: "Director disqualification",
      urgencyLevel: "N/A",
      reportText: report.text
    });

    const docxBuffer = await buildReportDocxBuffer({
      companyName: safeCompany,
      companyNumber,
      riskFocus: "Director disqualification",
      urgencyLevel: "N/A",
      reportText: report.text
    });

    const bodyText = [
      "AIVS Director Disqualification Report attached.",
      "",
      `Company: ${safeCompany}`,
      `Company number: ${companyNumber}`,
      "",
      "Summary:",
      `- Directors checked: ${report.summary.total_directors_checked}`,
      `- Red: ${report.summary.red}`,
      `- Amber: ${report.summary.amber}`,
      `- Green: ${report.summary.green}`,
      "",
      "Attached files:",
      `- ${pdfFilename}`,
      `- ${docxFilename}`,
      "",
      "This report uses the Companies House disqualified officers search and requires human review before reliance.",
      "",
      "AIVS Software Limited copyright 2026. All rights reserved."
