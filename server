async function extractProfileWithOpenAI({
  companyNameInput,
  companyNumberInput,
  primaryText,
  supportText,
  accountsFilename,
  supportFilenames,
  examinationWhy,
  examinationNeed,
  riskFocus,
  urgencyLevel,
  examinationPurpose
}) {
  if (!openai) {
    return fallbackProfileFromInputs({
      companyNameInput,
      companyNumberInput,
      primaryText,
      accountsFilename,
      supportFilenames
    });
  }

  const prompt = `
You are an evidence-first corporate due diligence extraction assistant for AIVS Software Limited.

Task:
Extract a structured company profile from uploaded accounts and supporting material.

Rules:
- Do not invent facts.
- If not found, use "Not found in uploaded material".
- Return strict JSON only.
- Do not include markdown.
- This is for corporate due diligence and human review.

User known inputs:
Company name input: ${companyNameInput || "not supplied"}
Company number input: ${companyNumberInput || "not supplied"}
Why: ${examinationWhy || "not supplied"}
Need: ${examinationNeed || "not supplied"}
Risk focus: ${riskFocus || "not supplied"}
Urgency: ${urgencyLevel || "not supplied"}
Purpose: ${examinationPurpose || "not supplied"}

Return JSON with this shape:
{
  "company_name": "",
  "company_number": "",
  "accounts_year_end": "",
  "directors": [],
  "auditor": "",
  "key_financial_wording": "",
  "red_flag_wording": "",
  "going_concern_indicators": [],
  "related_party_indicators": [],
  "debt_or_liability_indicators": [],
  "insurance_or_cyber_indicators": [],
  "document_summary": "",
  "source_documents": {
    "primary_accounts": "",
    "supporting_documents": []
  },
  "extraction_status": ""
}

Primary accounts text:
${cleanText(primaryText).slice(0, 60000)}

Supporting material text:
${cleanText(supportText).slice(0, 30000)}
`.trim();

  const completion = await openai.chat.completions.create({
    model: OPENAI_MODEL,
    messages: [{ role: "user", content: prompt }],
    temperature: 0.1
  });

  const raw = completion.choices?.[0]?.message?.content || "";
  const parsed = safeJsonParse(raw);

  if (!parsed) {
    return fallbackProfileFromInputs({
      companyNameInput,
      companyNumberInput,
      primaryText,
      accountsFilename,
      supportFilenames
    });
  }

  parsed.company_name = parsed.company_name || companyNameInput || "To be extracted";
  parsed.company_number = parsed.company_number || companyNumberInput || "To be extracted";
  parsed.source_documents = parsed.source_documents || {};
  parsed.source_documents.primary_accounts = accountsFilename || parsed.source_documents.primary_accounts || null;
  parsed.source_documents.supporting_documents = supportFilenames || [];

  return parsed;
}

