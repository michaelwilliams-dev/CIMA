function makeDocxRuns(value = "", options = {}) {
  const clean = String(value || "");
  const parts = clean.split(/\n+/);

  const runs = [];

  parts.forEach((part, index) => {
    if (index > 0) {
      runs.push(
        new TextRun({
          text: "",
          break: 1,
          font: "Arial",
          size: options.size ?? 20
        })
      );
    }

    runs.push(
      new TextRun({
        text: part || "",
        bold: options.bold === true,
        italics: options.italics === true,
        font: "Arial",
        size: options.size ?? 20,
        color: options.color || "243744"
      })
    );
  });

  return runs;
}

function makeDocxParagraph(text = "", options = {}) {
  return new Paragraph({
    children: makeDocxRuns(text, {
      size: options.size ?? 20,
      bold: options.bold === true,
      italics: options.italics === true,
      color: options.color || "243744"
    }),
    spacing: {
      before: options.before ?? 0,
      after: options.after ?? 120
    }
  });
}

function makeDocxHeading(text = "", level = HeadingLevel.HEADING_2) {
  let size = 24;
  let before = 260;
  let after = 120;

  if (level === HeadingLevel.HEADING_1) {
    size = 30;
    before = 320;
    after = 160;
  }

  if (level === HeadingLevel.HEADING_2) {
    size = 25;
    before = 280;
    after = 130;
  }

  return new Paragraph({
    heading: level,
    children: [
      new TextRun({
        text: String(text || ""),
        bold: true,
        font: "Arial",
        size,
        color: "14232B"
      })
    ],
    spacing: {
      before,
      after
    }
  });
}

function makeDocxCell(value = "", options = {}) {
  const isHeader = options.header === true;
  const isLabel = options.label === true;

  let fill = "FFFDF8";
  let color = "243744";
  let bold = false;

  if (isHeader) {
    fill = "14232B";
    color = "FFFFFF";
    bold = true;
  } else if (isLabel) {
    fill = "EDE8DF";
    color = "243744";
    bold = true;
  }

  return new TableCell({
    margins: {
      top: 120,
      bottom: 120,
      left: 140,
      right: 140
    },
    shading: {
      fill
    },
    children: [
      new Paragraph({
        children: makeDocxRuns(value, {
          bold,
          size: 19,
          color
        }),
        spacing: {
          after: 0
        }
      })
    ]
  });
}

function makeDocxTable(rows = []) {
  const cleanRows = Array.isArray(rows) ? rows : [];

  if (!cleanRows.length) {
    return new Table({
      width: {
        size: 100,
        type: WidthType.PERCENTAGE
      },
      rows: [
        new TableRow({
          children: [
            makeDocxCell("No records returned.", {
              header: true
            })
          ]
        })
      ]
    });
  }

  const colCount = Math.max(...cleanRows.map((row) => row.length || 1));
  const headerRow = cleanRows[0] || [];
  const bodyRows = cleanRows.slice(1);

  return new Table({
    width: {
      size: 100,
      type: WidthType.PERCENTAGE
    },
    borders: {
      top: { style: BorderStyle.SINGLE, size: 1, color: "B7AEA0" },
      bottom: { style: BorderStyle.SINGLE, size: 1, color: "B7AEA0" },
      left: { style: BorderStyle.SINGLE, size: 1, color: "B7AEA0" },
      right: { style: BorderStyle.SINGLE, size: 1, color: "B7AEA0" },
      insideHorizontal: { style: BorderStyle.SINGLE, size: 1, color: "DDD6C9" },
      insideVertical: { style: BorderStyle.SINGLE, size: 1, color: "DDD6C9" }
    },
    rows: [
      new TableRow({
        children: Array.from({ length: colCount }, (_, index) =>
          makeDocxCell(headerRow[index] ?? "", {
            header: true
          })
        )
      }),
      ...bodyRows.map((row) =>
        new TableRow({
          children: Array.from({ length: colCount }, (_, index) =>
            makeDocxCell(row[index] ?? "", {
              label: colCount === 2 && index === 0
            })
