function decodeBasicHtmlEntities(value = "") {
  return String(value || "")
    .replace(/&nbsp;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&lt;/gi, "<")
    .replace(/&gt;/gi, ">")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&pound;/gi, "\u00A3")
    .replace(/&euro;/gi, "\u20AC")
    .replace(/&#(\d+);/g, (_, code) => {
      try {
        return String.fromCharCode(Number(code));
      } catch {
        return "";
      }
    })
    .replace(/&#x([0-9a-f]+);/gi, (_, code) => {
      try {
        return String.fromCharCode(parseInt(code, 16));
      } catch {
        return "";
      }
    });
}

function ixbrlToPlainText(xhtml = "") {
  let text = String(xhtml || "");

  const bodyMatch = text.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
  if (bodyMatch) {
    text = bodyMatch[1];
  }

  text = text
    .replace(/<script[\s\S]*?<\/script>/gi, " ")
    .replace(/<style[\s\S]*?<\/style>/gi, " ")
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<\/(div|p|tr|td|th|li|h1|h2|h3|h4|h5|h6|section|article|table|ix:nonNumeric|ix:nonFraction)>/gi, "\n")
    .replace(/<[^>]+>/g, " ");

  text = decodeBasicHtmlEntities(text);

  return text
    .replace(/[ \t]+/g, " ")
    .replace(/\n[ \t]+/g, "\n")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

async function getLatestAccountsIxbrlForCompany(companyNumber) {
  const number = normaliseCompanyNumber(companyNumber);

  if (!number) {
    return {
      ok: false,
      error: "Company number required.",
      filename: null,
      filing: null,
      text: ""
    };
  }

  let filingHistory = await companiesHouseGet(
    `/company/${encodeURIComponent(number)}/filing-history?category=accounts&items_per_page=25`
  );

  let filings = filingHistory.data?.items || [];

  if (!filings.length) {
    filingHistory = await companiesHouseGet(
      `/company/${encodeURIComponent(number)}/filing-history?items_per_page=100`
    );

    filings = filingHistory.data?.items || [];
  }

  const latestAccountsFiling = filings.find((filing) => {
    const category = String(filing.category || "").toLowerCase();
    const type = String(filing.type || "").toUpperCase();
    const description = String(filing.description || "").toLowerCase();

    return (
      filing.links?.document_metadata &&
      (
        category === "accounts" ||
        type === "AA" ||
        description.includes("accounts")
      )
    );
  });

  if (!latestAccountsFiling) {
    return {
      ok: false,
      error: "No accounts filing with document metadata was found.",
      filename: null,
      filing: null,
      text: ""
    };
  }

  const documentMetadataPath = latestAccountsFiling.links.document_metadata;

  const metadataResult = await companiesHouseGetUrl(documentMetadataPath);

  if (!metadataResult.ok) {
    return {
      ok: false,
      error: `Could not retrieve Companies House document metadata: ${metadataResult.error || metadataResult.status}`,
      filename: null,
      filing: latestAccountsFiling,
      text: ""
    };
  }

  const metadata = metadataResult.data || {};
  const resources = metadata.resources || {};
  const resourceTypes = Object.keys(resources);

  if (!resources["application/xhtml+xml"]) {
    return {
      ok: false,
      error: `Companies House did not offer application/xhtml+xml. Available resource types: ${resourceTypes.join(", ") || "none"}.`,
      filename: null,
      filing: latestAccountsFiling,
      text: ""
    };
  }

  const contentPath = `${String(documentMetadataPath).replace(/\/$/, "")}/content`;

  const ixbrlResult = await companiesHouseFetchBinary(
    contentPath,
    "application/xhtml+xml"
  );

  if (!ixbrlResult.ok || !ixbrlResult.buffer) {
    return {
      ok: false,
      error: `Could not download Companies House iXBRL/XHTML accounts: ${ixbrlResult.error || ixbrlResult.status}`,
      filename: null,
      filing: latestAccountsFiling,
      text: ""
    };
  }

  const rawXhtml = ixbrlResult.buffer.toString("utf8");
  const text = ixbrlToPlainText(rawXhtml);

  const filingDate =
    latestAccountsFiling.date ||
    latestAccountsFiling.action_date ||
    "undated";

  const filename = `Companies_House_latest_accounts_ixbrl_${number}_${filingDate}.xhtml`
    .replace(/[^\w.\-]+/g, "_");

  return {
    ok: true,
    error: null,
    filename,
    filing: latestAccountsFiling,
    text
  };
}

function normalisePossibleJson(value, fallback = null) {
  if (!value) return fallback;

  if (typeof value === "object") {
    return value;
  }

  try {
    return JSON.parse(String(value));
  } catch {
    return fallback;
  }
}

