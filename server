function normaliseCompanyNameForPublicIntelligence(value = "") {
  return String(value || "")
    .replace(/\bPUBLIC LIMITED COMPANY\b/gi, "")
    .replace(/\bPLC\b/gi, "")
    .replace(/\bLIMITED\b/gi, "")
    .replace(/\bLTD\b/gi, "")
    .replace(/\s+/g, " ")
    .trim();
}

function extractDirectorInputsFromCompaniesHouseBundle(bundle = {}) {
  const officers = bundle.officers || {};
  const officerItems = Array.isArray(officers.items) ? officers.items : [];

  return officerItems
    .filter((officer) => !officer.resigned_on)
    .filter((officer) =>
      String(officer.officer_role || "")
        .toLowerCase()
        .includes("director")
    )
    .map((officer) => ({
      name: officer.name || "",
      officer_role: officer.officer_role || "",
      appointed_on: officer.appointed_on || "",
      date_of_birth: officer.date_of_birth || null,
