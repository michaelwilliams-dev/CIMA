function reportLines(reportText = "") {
  return String(reportText || "")
    .replace(/\r\n/g, "\n")
    .split("\n");
}

function cleanMarkdownLine(line = "") {
  return String(line || "")
    .replace(/^#{1,6}\s+/, "")
    .replace(/^\-\s+/, "")
    .replace(/\*\*/g, "")
    .trim();
}

function isMarkdownTableLine(line = "") {
  const value = String(line || "").trim();
  return value.startsWith("|") && value.endsWith("|") && value.includes("|");
}

function isMarkdownTableSeparator(line = "") {
  const value = String(line || "").trim();

  if (!isMarkdownTableLine(value)) return false;

  const cells = value
    .split("|")
    .slice(1, -1)
    .map((cell) => cell.trim());

  return cells.length > 0 && cells.every((cell) => /^:?-{3,}:?$/.test(cell));
}

function parseMarkdownTable(lines = []) {
  const tableLines = lines
    .map((line) => String(line || "").trim())
    .filter((line) => isMarkdownTableLine(line) && !isMarkdownTableSeparator(line));

  return tableLines.map((line) =>
    line
      .split("|")
      .slice(1, -1)
      .map((cell) => cleanMarkdownLine(cell))
  );
}

function splitReportIntoBlocks(reportText = "") {
  const lines = reportLines(reportText);
  const blocks = [];
  let tableBuffer = [];

  function flushTable() {
    if (tableBuffer.length) {
      const rows = parseMarkdownTable(tableBuffer);
      if (rows.length) {
        blocks.push({
          type: "table",
          rows
        });
      }
      tableBuffer = [];
    }
  }

  for (const rawLine of lines) {
    const line = String(rawLine || "").trim();

    if (isMarkdownTableLine(line)) {
      tableBuffer.push(line);
      continue;
    }

    flushTable();

    if (!line) {
      blocks.push({
        type: "space"
      });
      continue;
    }

    if (line.startsWith("# ")) {
      blocks.push({
        type: "heading1",
        text: cleanMarkdownLine(line)
      });
      continue;
    }

    if (line.startsWith("## ")) {
      blocks.push({
        type: "heading2",
        text: cleanMarkdownLine(line)
      });
      continue;
    }

    if (line.startsWith("- ")) {
      blocks.push({
        type: "bullet",
        text: cleanMarkdownLine(line)
      });
      continue;
    }

    blocks.push({
      type: "paragraph",
      text: cleanMarkdownLine(line)
    });
  }

  flushTable();

  return blocks;
}

function ensurePdfSpace(doc, neededHeight = 40) {
  const bottom = doc.page.height - doc.page.margins.bottom;

  if (doc.y + neededHeight > bottom) {
    doc.addPage();
  }
}

function drawPdfTable(doc, rows = []) {
  if (!rows.length) return;

  const usableWidth = doc.page.width - doc.page.margins.left - doc.page.margins.right;
  const colCount = Math.max(...rows.map((row) => row.length));

  let colWidths;

  if (colCount === 4) {
    colWidths = [
      usableWidth * 0.24,
      usableWidth * 0.18,
      usableWidth * 0.18,
      usableWidth * 0.40
    ];
  } else if (colCount === 3) {
    colWidths = [
      usableWidth * 0.34,
      usableWidth * 0.33,
      usableWidth * 0.33
    ];
  } else {
    colWidths = Array.from({ length: colCount }, () => usableWidth / colCount);
  }

  const left = doc.page.margins.left;
  const padding = 5;

  doc.moveDown(0.4);

  rows.forEach((row, rowIndex) => {
    const isHeader = rowIndex === 0;

    const cellHeights = colWidths.map((width, index) => {
      const text = String(row[index] || "");
      return doc.heightOfString(text, {
        width: width - padding * 2,
        align: "left"
      }) + padding * 2;
    });

    const rowHeight = Math.max(24, ...cellHeights);

    ensurePdfSpace(doc, rowHeight + 8);

    let x = left;
    const y = doc.y;

    row.forEach((cell, index) => {
      const width = colWidths[index] || colWidths[colWidths.length - 1];

      doc
        .lineWidth(0.5)
        .rect(x, y, width, rowHeight)
        .stroke();

      doc
        .fontSize(isHeader ? 8.5 : 8)
        .text(String(cell || ""), x + padding, y + padding, {
          width: width - padding * 2,
          align: "left"
        });

      x += width;
    });

    doc.y = y + rowHeight;
    doc.x = left;
  });

  doc.x = left;
  doc.moveDown(0.7);
  doc.x = left;
}

function buildReportPdfBuffer({
  companyName,
  companyNumber,
  riskFocus,
  urgencyLevel,
  reportText
}) {
  return new Promise((resolve, reject) => {
    const doc = new PDFDocument({
      size: "A4",
      margin: 42,
      bufferPages: true
    });

    const chunks = [];

    doc.on("data", (chunk) => chunks.push(chunk));
    doc.on("end", () => resolve(Buffer.concat(chunks)));
    doc.on("error", reject);

    const generatedAt = new Date().toISOString();
    const blocks = splitReportIntoBlocks(reportText);

    doc
      .fontSize(13)
      .text("AIVS Company Examiner", { align: "left" });

    doc.moveDown(0.3);

    doc
      .fontSize(8.5)
      .text(`Generated at: ${generatedAt}`);

    doc.moveDown(0.8);

    for (const block of blocks) {
      if (block.type === "space") {
        doc.moveDown(0.3);
        continue;
      }

      if (block.type === "heading1") {
        ensurePdfSpace(doc, 30);
        doc.moveDown(0.5);
        doc.fontSize(11).text(block.text);
        doc.moveDown(0.2);
        continue;
      }

      if (block.type === "heading2") {
        ensurePdfSpace(doc, 30);
        doc.moveDown(0.55);
        doc.fontSize(13).text(block.text);
        doc.moveDown(0.2);
        continue;
      }

      if (block.type === "bullet") {
        ensurePdfSpace(doc, 24);
        doc.fontSize(10).text(`- ${block.text}`, {
          align: "left",
          indent: 12,
          lineGap: 3
        });
        doc.moveDown(0.25);
        continue;
      }

      if (block.type === "table") {
        drawPdfTable(doc, block.rows);
        continue;
      }

      ensurePdfSpace(doc, 24);
      doc.fontSize(10).text(block.text, {
        align: "left",
        lineGap: 3
      });
      doc.moveDown(0.35);
    }

    doc.moveDown(1.5);

    ensurePdfSpace(doc, 60);

    doc
      .fontSize(8)
      .text(
        "This report supports company examination using available public Companies House data. It is not legal, financial, investment, sanctions, credit, procurement or professional advice. All outputs require human review against source evidence before reliance.",
        { align: "left" }
      );

    doc.moveDown();

    doc
      .fontSize(8)
      .text("(c) AIVS Software Limited copyright 2026. All rights reserved.");

    doc.end();
  });
}

