function cleanText(value = "") {
  return String(value || "")
    .replace(/\u0000/g, "")
    .replace(/[ \t]+/g, " ")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

function safeJsonParse(raw) {
  try {
    const cleaned = String(raw || "")
      .replace(/^```json\s*/i, "")
      .replace(/^```\s*/i, "")
      .replace(/```$/i, "")
      .trim();

    return JSON.parse(cleaned);
  } catch (err) {
    return null;
  }
}

async function extractPdfTextFromBuffer(buffer, filename = "document") {
  try {
    const parsed = await pdfParse(buffer);
    return cleanText(parsed.text || "");
  } catch (err) {
    console.warn("WARNING PDF extraction failed:", filename, err.message);
    return "";
  }
}

function normaliseCompanyNumber(value = "") {
  return String(value || "")
    .trim()
    .replace(/\s+/g, "")
    .toUpperCase();
}

function companiesHouseHeaders(accept = "application/json") {
  if (!COMPANIES_HOUSE_API_KEY) return {};

  const token = Buffer.from(`${COMPANIES_HOUSE_API_KEY}:`).toString("base64");

  return {
    Authorization: `Basic ${token}`,
    Accept: accept
  };
}

function absoluteCompaniesHouseUrl(value = "") {
  const v = String(value || "").trim();

  if (!v) return "";

  if (/^https?:\/\//i.test(v)) {
    return v;
  }

  if (v.startsWith("/document/")) {
    return `https://document-api.company-information.service.gov.uk${v}`;
  }

  return `https://api.company-information.service.gov.uk${v.startsWith("/") ? v : `/${v}`}`;
}

async function companiesHouseGet(pathname) {
  if (!COMPANIES_HOUSE_API_KEY) {
    return {
      ok: false,
      status: 0,
      error: "COMPANIES_HOUSE_API_KEY not set.",
      data: null
    };
  }

  const url = `https://api.company-information.service.gov.uk${pathname}`;

  try {
    const res = await fetch(url, {
      method: "GET",
      headers: companiesHouseHeaders("application/json")
    });

    const text = await res.text();
    let data = null;

    try {
      data = text ? JSON.parse(text) : null;
    } catch {
      data = { raw: text };
    }

    if (!res.ok) {
      return {
        ok: false,
        status: res.status,
        error: data?.error || data?.message || `Companies House request failed: ${res.status}`,
        data
      };
    }

    return {
      ok: true,
      status: res.status,
      error: null,
      data
    };
  } catch (err) {
    return {
      ok: false,
      status: 0,
      error: err.message,
      data: null
    };
  }
}

