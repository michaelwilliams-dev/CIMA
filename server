const MAX_OFFICERS_FOR_NETWORK_TRACE = 100;

const OFFICER_NETWORK_TRACE_SKIPPED_MESSAGE =
  "Officer appointment trace-back was not expanded because this company has a large officer/director structure. Review Companies House officer records directly if director network history is material.";

async function getOfficerAppointmentsFromOfficerList(officersData) {
  const officerItems = officersData?.items || [];

  if (!officerItems.length) {
    return [];
  }

  const appointmentResults = await Promise.all(
    officerItems.map(async (officer) => {
      const appointmentsPath = officer.links?.officer?.appointments || "";

      if (!appointmentsPath) {
        return {
          officer_name: officer.name || "Unknown officer",
          person_number: officer.person_number || null,
          date_of_birth: officer.date_of_birth || null,
          nationality: officer.nationality || null,
          country_of_residence: officer.country_of_residence || null,
          company_role: officer.officer_role || null,
          company_appointed_on: officer.appointed_on || null,
          appointments_path: null,
          ok: false,
          status: 0,
          error: "No officer appointments link returned by Companies House.",
          total_results: 0,
          active_appointments: [],
          resigned_appointments: [],
          all_appointments: []
        };
      }

      const separator = appointmentsPath.includes("?") ? "&" : "?";

      const result = await companiesHouseGet(
        `${appointmentsPath}${separator}items_per_page=50`
      );

      const appointmentItems = result.data?.items || [];

      const cleanedAppointments = appointmentItems.map((appointment) => ({
        company_name: appointment.appointed_to?.company_name || "",
        company_number: appointment.appointed_to?.company_number || "",
        company_status: appointment.appointed_to?.company_status || "",
        company_type: appointment.appointed_to?.company_type || "",
        role: appointment.officer_role || "",
        appointed_on: appointment.appointed_on || "",
        resigned_on: appointment.resigned_on || null,
        occupation: appointment.occupation || null,
        address: appointment.address || null,
        links: appointment.links || null
      }));

      return {
        officer_name: officer.name || "Unknown officer",
        person_number: officer.person_number || null,
        date_of_birth: officer.date_of_birth || null,
        nationality: officer.nationality || null,
        country_of_residence: officer.country_of_residence || null,
        company_role: officer.officer_role || null,
        company_appointed_on: officer.appointed_on || null,
        appointments_path: appointmentsPath,
        ok: result.ok,
        status: result.status,
        error: result.error,
        total_results: result.data?.total_results ?? cleanedAppointments.length,
        active_appointments: cleanedAppointments.filter((item) => !item.resigned_on),
        resigned_appointments: cleanedAppointments.filter((item) => item.resigned_on),
        all_appointments: cleanedAppointments
      };
    })
  );

  return appointmentResults;
}

async function getAllCompanyOfficers(companyNumber) {
  const number = normaliseCompanyNumber(companyNumber);
  const itemsPerPage = 100;

  let startIndex = 0;
  let allItems = [];
  let firstResult = null;
  let latestData = null;

  while (true) {
    const result = await companiesHouseGet(
      `/company/${encodeURIComponent(number)}/officers?items_per_page=${itemsPerPage}&start_index=${startIndex}`
    );

    if (!firstResult) {
      firstResult = result;
    }

    if (!result.ok) {
      return result;
    }

    const data = result.data || {};
    const items = Array.isArray(data.items) ? data.items : [];

    allItems.push(...items);
    latestData = data;

    const totalResults = Number(data.total_results ?? allItems.length);

    startIndex += itemsPerPage;

    if (items.length === 0 || allItems.length >= totalResults) {
      break;
    }
  }

  return {
    ok: firstResult?.ok ?? true,
    status: firstResult?.status ?? 200,
    error: firstResult?.error ?? null,
    data: {
      ...(latestData || {}),
      items: allItems,
      total_results: Number(latestData?.total_results ?? allItems.length),
      items_per_page: itemsPerPage,
      start_index: 0,
      aivs_all_pages_loaded: true,
      aivs_items_loaded: allItems.length
    }
  };
}

async function getCompaniesHouseBundle(companyNumber) {
  const number = normaliseCompanyNumber(companyNumber);

  if (!number) {
    return {
      ok: false,
      error: "Company number required.",
      company_number: "",
      profile: null,
      officers: null,
      officer_appointments: [],
      psc: null,
      filing_history: null,
      source_status: {
        profile: { ok: false, status: 0, error: "Company number required." },
        officers: { ok: false, status: 0, error: "Company number required." },
        officer_appointments: { ok: false, status: 0, error: "Company number required." },
        psc: { ok: false, status: 0, error: "Company number required." },
        filing_history: { ok: false, status: 0, error: "Company number required." }
      }
    };
  }

  const [profile, psc, filingHistory] = await Promise.all([
    companiesHouseGet(`/company/${encodeURIComponent(number)}`),
    companiesHouseGet(`/company/${encodeURIComponent(number)}/persons-with-significant-control?items_per_page=35`),
    companiesHouseGet(`/company/${encodeURIComponent(number)}/filing-history?items_per_page=35`)
  ]);

  const officers = await getAllCompanyOfficers(number);

  const allOfficerItems = Array.isArray(officers.data?.items)
    ? officers.data.items
    : [];

  const activeDirectorItemsForTrace = allOfficerItems
    .filter((officer) => !officer.resigned_on)
    .filter((officer) =>
      String(officer.officer_role || "")
        .toLowerCase()
        .includes("director")
    );

  const officerTraceSkipped =
    officers.ok &&
    activeDirectorItemsForTrace.length > MAX_OFFICERS_FOR_NETWORK_TRACE;

  const activeDirectorOfficerData = {
    ...(officers.data || {}),
    items: activeDirectorItemsForTrace,
    total_results: activeDirectorItemsForTrace.length,
    aivs_trace_scope: "active_directors_only"
  };

  const officerAppointments =
    officers.ok && !officerTraceSkipped
      ? await getOfficerAppointmentsFromOfficerList(activeDirectorOfficerData)
      : [];

  const officerAppointmentSourceStatus = officerTraceSkipped
    ? {
        ok: true,
        status: 200,
        error: OFFICER_NETWORK_TRACE_SKIPPED_MESSAGE,
        skipped: true,
        all_officer_count: allOfficerItems.length,
        active_director_count: activeDirectorItemsForTrace.length,
        threshold: MAX_OFFICERS_FOR_NETWORK_TRACE
      }
    : {
        ok: officers.ok,
        status: officers.status,
        error: officers.ok
          ? null
          : officers.error || "Officer appointment records could not be returned.",
        skipped: false,
        all_officer_count: allOfficerItems.length,
        active_director_count: activeDirectorItemsForTrace.length,
        threshold: MAX_OFFICERS_FOR_NETWORK_TRACE
      };

  return {
    ok: profile.ok,
    error: profile.error,
    company_number: number,
    profile: profile.data,
    officers: officers.data,
    officer_appointments: officerAppointments,
    officer_network_trace: {
      skipped: officerTraceSkipped,
      officer_count: allOfficerItems.length,
      active_director_count: activeDirectorItemsForTrace.length,
      threshold: MAX_OFFICERS_FOR_NETWORK_TRACE,
      message: officerTraceSkipped ? OFFICER_NETWORK_TRACE_SKIPPED_MESSAGE : null
    },
    psc: psc.data,
    filing_history: filingHistory.data,
    source_status: {
      profile: {
        ok: profile.ok,
        status: profile.status,
        error: profile.error
      },
      officers: {
        ok: officers.ok,
        status: officers.status,
        error: officers.error,
        all_pages_loaded: officers.data?.aivs_all_pages_loaded === true,
        items_loaded: officers.data?.aivs_items_loaded ?? allOfficerItems.length
      },
      officer_appointments: officerAppointmentSourceStatus,
      psc: {
        ok: psc.ok,
        status: psc.status,
        error: psc.error
      },
      filing_history: {
        ok: filingHistory.ok,
        status: filingHistory.status,
        error: filingHistory.error
      }
    }
  };
}

